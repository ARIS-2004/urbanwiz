# ─────────────────────────────────────────────────────────────
#  URBANWIZ FRONTEND — environment configuration
#  Copy this file to ".env.local" (or ".env") and adjust if needed.
#  This is the ONLY place the frontend learns where the backend is.
# ─────────────────────────────────────────────────────────────

# Base URL of the Urbanwiz backend API.
# Must be prefixed with NEXT_PUBLIC_ so the browser can read it.
# If you change the backend PORT in Backend/.env, change it here to match.
NEXT_PUBLIC_API_URL=http://localhost:5000
